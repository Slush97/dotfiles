# Chalk-pastel dircolors — matches esocidae/Starship palette
# Uses 256-color (38;5;N) and truecolor (38;2;R;G;B) escapes

TERM xterm*
TERM screen*
TERM tmux*
TERM alacritty
TERM foot
TERM kitty
TERM rxvt*
TERM linux

# === Core types ===
NORMAL                00
FILE                  00
RESET                 0

# Directories — soft teal (matching Starship directory #80AE9E)
DIR                   01;38;2;128;174;158

# Symlinks — lavender (matching git_branch #9E80AE)
